{
  "manifest_version": 3,
  "name": "BacklinkAI",
  "name_en": "Backlink AI Assistant",
  "version": "1.0.3",
  "description": "AI 驱动的外链发布助手，自动读取网页内容，生成个性化评论/站点描述，智能填充表单",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "sidePanel",
    "identity"
  ],
  "host_permissions": [
    "https://openai-baibei.openai.azure.com/*",
    "https://*.supabase.co/*",
    "<all_urls>"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "BacklinkAI"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html"
}
