# Azure OpenAI API 配置示例
# 复制此文件为 .env 并填入真实的 API Key
VITE_AZURE_API_KEY=your_api_key_here
VITE_AZURE_ENDPOINT=https://your-resource.openai.azure.com
VITE_AZURE_DEPLOYMENT=gpt-4.1
VITE_AZURE_API_VERSION=2024-12-01-preview

# Supabase 配置
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
